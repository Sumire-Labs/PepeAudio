# Discord application credentials (https://discord.com/developers/applications)
#
# SECURITY: DISCORD_TOKEN is the bot's master credential — anyone who has it can
# fully control the bot. Copy this file to `.env` (gitignored), never commit it,
# and on a shared/production host restrict it with `chmod 600 .env`. If it ever
# leaks, regenerate it in the Developer Portal immediately.
#
# In production, prefer a file-mounted secret over putting the token in an env
# var (env vars are visible via `docker inspect`, /proc/<pid>/environ, and to
# child processes). Set DISCORD_TOKEN_FILE to a path and the token is read from
# that file instead — this is what docker-compose.yml wires up:
#   DISCORD_TOKEN_FILE=/run/secrets/discord_token
DISCORD_TOKEN=
# CLIENT_ID is the public application id (not a secret).
CLIENT_ID=
# Optional: set during development for instant guild-scoped slash command registration.
# Leave empty in production to register commands globally.
GUILD_ID=

# Optional overrides
LOG_LEVEL=info
# Directory for the SQLite database file. Unset = project root (fine for local
# runs). In Docker, point this at a mounted volume so guild settings survive
# container recreation (docker-compose.yml sets DATA_DIR=/data).
DATA_DIR=
# Absolute or relative path to an ffmpeg binary. If unset, the resolver checks
# bin/ffmpeg(.exe) (populated by `npm run setup-ffmpeg`), then falls back to ffmpeg-static.
FFMPEG_PATH=
# Optional: folder containing your own HRIR/BRIR WAV file(s) for the Aura Sound
# System (bring-your-own — nothing is bundled or downloaded). Every supported
# file (mono/stereo, or a HeSuVi 14ch BRIR) becomes a selectable "Aura Preset"
# in the panel; the guild's choice persists. Defaults to assets/hrir_profiles/
# if unset. See the README's "Aura Sound System" section for the format rules.
HRIR_PROFILES_DIR=
