# Copy to .env and fill in. NEVER commit the real .env.
# .NET binds double-underscore (__) to config hierarchy: DISCORD__TOKEN -> Discord:Token

# --- Discord ---
DISCORD__TOKEN=
DISCORD__CLIENTID=
DISCORD__CLIENTSECRET=
# Fleet-wide total shard count (identical across every container)
DISCORD__TOTALSHARDS=1
# Comma-separated shard ids this container owns, e.g. 0,1,2,3
DISCORD__SHARDIDS=0
DISCORD__USEGLOBALCOMMANDS=false
DISCORD__DEVGUILDID=

# --- Data / cache ---
CONNECTIONSTRINGS__POSTGRES=Host=postgres;Port=5432;Database=pepeaudio;Username=pepeaudio;Password=change-me
CONNECTIONSTRINGS__VALKEY=valkey:6379

# Values used by the postgres/valkey containers in docker-compose
POSTGRES_DB=pepeaudio
POSTGRES_USER=pepeaudio
POSTGRES_PASSWORD=change-me

# --- Source providers (optional; metadata only for Spotify/Apple) ---
SPOTIFY__CLIENTID=
SPOTIFY__CLIENTSECRET=
APPLEMUSIC__TEAMID=
APPLEMUSIC__KEYID=
APPLEMUSIC__PRIVATEKEYPATH=/run/secrets/applemusic_private_key
SOUNDCLOUD__CLIENTID=

# --- yt-dlp extraction (binds to the Sources config section) ---
# player_client: yt-dlp's default multi-client set. Override only if needed.
SOURCES__PLAYERCLIENT=default
SOURCES__POTBASEURL=http://bgutil-provider:4416
SOURCES__COOKIESFILE=

# --- WebGUI (backend-authority OAuth) ---
WEBGUI__ENABLED=true
WEBGUI__BASEURL=http://localhost:3000
WEBGUI__JWTSIGNINGKEY=
WEBGUI__OAUTH__CLIENTID=
WEBGUI__OAUTH__CLIENTSECRET=
WEBGUI__OAUTH__REDIRECTURI=
# Admin dashboard allowlist (indexed): WEBGUI__ADMINUSERIDS__0=<your discord user id>
WEBGUI__ADMINUSERIDS__0=

# --- Runtime ---
ASPNETCORE_ENVIRONMENT=Production
PEPE__CONTAINERID=shard-0
